{
  "$schema": "https://turborepo.org/schema.json",
  "extends": [
    "//"
  ],
  "tasks": {
    "build": {
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$"],
      "dependsOn": [
        "^build"
      ]
    },
    "generate:typography-docs": {
      "cache": true,
      "dependsOn": [
        "build"
      ],
      "inputs": [
        "scripts/generate-typography-docs.js"
      ],
      "outputs": [
        "docs/typography-utility-classes.md"
      ]
    }
  }
}
