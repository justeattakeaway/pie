$font-interactive-l-family: $font-family-primary;
$font-interactive-l-weight: $font-weight-extrabold;
// Body-s font theme
$font-body-s-size: $font-size-14;
$font-body-s-line-height: $font-line-height-20;
$font-body-s-family: $font-family-primary;
