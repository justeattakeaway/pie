$font-subheading-l-weight: $font-weight-regular;
// Interactive-xs font theme
$font-interactive-xs-size: $font-size-14;
$font-interactive-xs-line-height: $font-line-height-20;
$font-interactive-xs-family: $font-family-primary;
$font-interactive-xs-weight: $font-weight-bold;
// Interactive-s font theme
