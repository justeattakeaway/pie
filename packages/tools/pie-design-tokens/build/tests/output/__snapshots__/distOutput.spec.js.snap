@media (prefers-color-scheme: dark) {
    html[data-darkmode-system]:not([data-color-mode]) {
        $color-background-default: $color-truffle-100;
        $color-background-subtle: $color-truffle-80;
        $color-background-dark: $color-truffle-5;
        $color-container-default: $color-truffle-90;
        $color-container-subtle: $color-truffle-80;
        $color-container-strong: $color-truffle-70;
        $color-container-dark: $color-truffle-90;
        $color-container-light: $color-white;
        $color-container-inverse: $color-white;
        $color-container-inverse-alternative: $color-truffle-70;
        $color-container-base: rgb(43,42,40,0.62);
        $color-container-neutral: rgb(89,86,79,0.72);
        $color-container-prominent: rgb(43,42,40,0.42);
        $color-container-base-dark: rgb(43,42,40,0.62);
        $color-border-default: $color-truffle-70;
        $color-border-subtle: $color-truffle-75;
        $color-border-strong: $color-truffle-65;
        $color-border-inverse: $color-truffle-20;
        $color-border-selected: $color-truffle-30;
        $color-border-selected-brand: $color-orange;
        $color-border-form: $color-truffle-55;
        $color-border-neutral: $color-truffle-80;
        $color-border-decorative-brand: $color-orange-30;
        $color-divider-default: rgb(255,255,255,0.20);
        $color-divider-inverse: rgb(0,0,0,0.08);
        $color-interactive-brand: $color-orange;
        $color-interactive-primary: $color-white;
        $color-interactive-secondary: $color-truffle-75;
        $color-interactive-inverse: $color-truffle-90;
        $color-interactive-light: $color-white;
        $color-interactive-dark: $color-truffle-90;
        $color-interactive-form: $color-truffle-55;
        $color-interactive-error: $color-red-50;
        $color-overlay: rgb(0,0,0,0.55);
        $color-transparent: rgb(255,255,255,0);
        $color-support-error: $color-red-50;
        $color-support-warning: $color-yellow-40;
        $color-support-positive: $color-green-30;
        $color-support-info: $color-blue-30;
        $color-support-neutral: $color-truffle-100;
        $color-support-error-02: $color-red-90;
        $color-support-error-tonal: $color-red-100;
        $color-support-warning-02: $color-yellow-80;
        $color-support-warning-tonal: $color-yellow-90;
        $color-support-positive-02: $color-green-80;
        $color-support-positive-tonal: $color-green-90;
        $color-support-info-02: $color-blue-80;
        $color-support-info-tonal: $color-blue-90;
        $color-support-info-inverse: $color-blue;
        $color-support-positive-inverse: $color-green;
        $color-support-neutral-persistent: $color-truffle-20;
        $color-support-error-inverse: $color-red;
        $color-support-warning-inverse: $color-yellow-75;
        $color-support-brand-01: $color-orange-30;
        $color-support-brand-02: $color-orange-75;
        $color-support-brand-tonal: $color-orange-90;
        $color-support-brand-03: $color-cupcake-30;
        $color-support-brand-03-subtle: $color-cupcake-80;
        $color-support-brand-03-tonal: $color-cupcake-90;
        $color-support-brand-04: $color-berry-40;
        $color-support-brand-04-subtle: $color-berry-80;
        $color-support-brand-04-tonal: $color-berry-90;
        $color-support-brand-05: $color-turmeric-40;
        $color-support-brand-05-subtle: $color-turmeric-75;
        $color-support-brand-05-tonal: $color-turmeric-80;
        $color-support-brand-06: $color-aubergine-70;
        $color-support-brand-06-subtle: $color-aubergine-90;
        $color-support-brand-06-tonal: $color-aubergine-100;
        $color-support-brand-07: $color-tomato-50;
        $color-support-brand-07-subtle: $color-tomato-90;
        $color-support-brand-08: $color-latte-30;
        $color-support-brand-08-subtle: $color-latte-80;
        $color-support-brand-08-tonal: $color-latte-90;
        $color-braze-container-01: $color-orange-75;
        $color-braze-container-03: $color-cupcake-70;
        $color-braze-container-04: $color-berry-70;
        $color-braze-container-05: $color-turmeric-70;
        $color-braze-container-08: $color-latte-70;
        $color-content-default: rgb(255,255,255,0.9);
        $color-content-subdued: rgb(255,255,255,0.86);
        $color-content-interactive-brand: $color-orange-30;
        $color-content-interactive-light: rgb(255,255,255,0.9);
        $color-content-interactive-primary: rgb(0,0,0,0.76);
        $color-content-interactive-secondary: rgb(255,255,255,0.9);
        $color-content-interactive-tertiary: $color-white;
        $color-content-interactive-subdued: rgb(255,255,255,0.8);
        $color-content-interactive-inverse: rgb(255,255,255,0.9);
        $color-content-interactive-dark: rgb(0,0,0,0.76);
        $color-content-interactive-error: $color-red-10;
        $color-content-light: rgb(255,255,255,0.9);
        $color-content-dark: rgb(0,0,0,0.76);
        $color-content-inverse: rgb(0,0,0,0.76);
        $color-content-link: $color-white;
        $color-content-link-distinct: $color-blue-10;
        $color-content-link-light: $color-white;
        $color-content-link-inverse: $color-charcoal-80;
        $color-content-link-visited: $color-system-purple-10;
        $color-content-link-visited-inverse: $color-system-purple;
        $color-content-error: $color-red-10;
        $color-content-placeholder: rgb(255,255,255,0.55);
        $color-content-positive: $color-green-10;
        $color-content-disabled: rgb(255,255,255,0.30);
        $color-content-brand: $color-orange-30;
        $color-content-default-solid: $color-white;
        $color-content-subdued-solid: $color-charcoal-30;
        $color-content-light-solid: $color-white;
        $color-content-inverse-solid: $color-charcoal-70;
        $color-content-dark-solid: $color-charcoal-80;
        $color-content-disabled-solid: $color-charcoal-50;
        $color-content-placeholder-solid: $color-charcoal-50;
        $color-content-brand-solid: $color-orange-30;
        $color-content-error-solid: $color-red-10;
        $color-content-positive-solid: $color-green-10;
        $color-content-interactive-light-solid: $color-white;
        $color-content-interactive-primary-solid: $color-charcoal-80;
        $color-content-interactive-secondary-solid: $color-white;
        $color-content-interactive-inverse-solid: $color-white;
        $color-content-interactive-dark-solid: $color-charcoal-80;
        $color-content-interactive-brand-solid: $color-orange-30;
        $color-content-interactive-error-solid: $color-red-10;
        $color-content-interactive-subdued-solid: $color-charcoal-40;
        $color-hover-01-bg: #fff;
        $color-hover-01: 8%;
        $color-hover-01-dark-bg: #000;
        $color-hover-01-dark: 4%;
        $color-hover-02-bg: #000;
        $color-hover-02: 4%;
        $color-hover-02-light-bg: #fff;
        $color-hover-02-light: 8%;
        $color-active-01-bg: #fff;
        $color-active-01: 20%;
        $color-active-01-dark-bg: #000;
        $color-active-01-dark: 12%;
        $color-active-02-bg: #000;
        $color-active-02: 12%;
        $color-active-02-light-bg: #fff;
        $color-active-02-light: 20%;
        $color-resting-bg: #000;
        $color-resting: 0%;
        $color-focus-inner: $color-black;
        $color-focus-outer: $color-blue-30;
        $color-disabled-01: $color-truffle-80;
        $color-disabled-01-inverse: $color-truffle-20;
        $color-skeleton-01: $color-truffle-80;
        $color-skeleton-02: $color-truffle-75;
        $color-skeleton-03: $color-truffle-90;
        $color-skeleton-shimmer-01: $color-truffle-75;
        $color-skeleton-shimmer-02: $color-truffle-70;
        $color-skeleton-shimmer-03: $color-truffle-80;
        $color-thirdparty-apple-container-primary: $color-white;
        $color-thirdparty-apple-content-primary: $color-black;
        $color-thirdparty-apple-container-secondary: $color-black;
        $color-thirdparty-apple-content-secondary: $color-white;
        $color-thirdparty-android-background-dashboard: $color-black;
        $color-thirdparty-facebook-container-primary: $color-thirdparty-facebook-blue;
        $color-thirdparty-facebook-content-primary: $color-white;
        $color-thirdparty-facebook-container-secondary: $color-black;
        $color-thirdparty-facebook-content-secondary: $color-white;
        $color-thirdparty-google-container-primary: $color-thirdparty-google-grey-100;
        $color-thirdparty-google-content-primary: $color-thirdparty-google-grey-30;
        $color-thirdparty-google-content-primary-subdued: $color-thirdparty-google-grey-30;
        $color-thirdparty-google-border-primary: $color-thirdparty-google-grey-30;
        $color-thirdparty-google-container-secondary: $color-white;
        $color-thirdparty-google-content-secondary: $color-thirdparty-google-grey-100;
        $color-thirdparty-google-content-secondary-subdued: $color-thirdparty-google-grey-70;
        $color-thirdparty-google-border-secondary: $color-thirdparty-google-grey-60;
        $color-thirdparty-microsoft-container-primary: $color-thirdparty-microsoft-grey-80;
        $color-thirdparty-microsoft-content-primary: $color-white;
        $color-thirdparty-microsoft-border-primary-bg: #000;
        $color-thirdparty-microsoft-border-primary: 0%;
        $color-thirdparty-microsoft-container-secondary: $color-white;
        $color-thirdparty-microsoft-content-secondary: $color-thirdparty-microsoft-grey-70;
        $color-thirdparty-microsoft-border-secondary: $color-thirdparty-microsoft-grey-60;
        $color-thirdparty-coop-container-primary: $color-thirdparty-coop-blue-90;
        $color-thirdparty-morrisons-container-primary: $color-thirdparty-morrisons-green-90;
    }
}
// Global tokens - Font
$font-family-alternative: 'JETSansVF2';
$font-family-code: 'PTMono';
$font-family-primary: 'JetSansDigital';
$font-family-secondary: 'Arial';
$font-line-height-16: 16;
$font-line-height-20: 20;
$font-line-height-24: 24;
$font-line-height-28: 28;
$font-line-height-32: 32;
$font-line-height-36: 36;
$font-line-height-52: 52;
$font-paragraph-spacing-01: 16;
$font-paragraph-spacing-02: 14;
$font-paragraph-spacing-03: 12;
$font-size-12: 12;
$font-size-12-line-height: 16;
$font-size-14: 14;
$font-size-14-line-height: 20;
$font-size-16: 16;
$font-size-16-line-height: 24;
$font-size-20: 20;
$font-size-20-line-height: 24;
$font-size-24: 24;
$font-size-24-line-height: 28;
$font-size-28: 28;
$font-size-28-line-height: 32;
$font-size-32: 32;
$font-size-32-line-height: 36;
$font-size-48: 48;
$font-size-48-line-height: 52;
$font-style-italic: italic;
$font-style-underline: underline;
$font-weight-black: 900;
$font-weight-bold: 700;
$font-weight-extrablack: 1000;
$font-weight-extrabold: 800;
$font-weight-regular: 400;
// Alias tokens - Font
// Heading-xs font theme
$font-heading-xs-size--wide: $font-size-16;
$font-heading-xs-line-height--wide: $font-line-height-20;
$font-heading-xs-size--narrow: $font-size-14;
$font-heading-xs-line-height--narrow: $font-line-height-20;
$font-heading-xs-family: $font-family-primary;
$font-heading-xs-weight: $font-weight-black;
// Heading-s font theme
$font-heading-s-size--wide: $font-size-20;
$font-heading-s-line-height--wide: $font-line-height-24;
$font-heading-s-size--narrow: $font-size-16;
$font-heading-s-line-height--narrow: $font-line-height-20;
$font-heading-s-family: $font-family-primary;
$font-heading-s-weight: $font-weight-black;
// Heading-m font theme
$font-heading-m-size--wide: $font-size-24;
$font-heading-m-line-height--wide: $font-line-height-28;
$font-heading-m-size--narrow: $font-size-20;
$font-heading-m-line-height--narrow: $font-line-height-24;
$font-heading-m-family: $font-family-primary;
$font-heading-m-weight: $font-weight-black;
// Heading-l font theme
$font-heading-l-size--wide: $font-size-28;
$font-heading-l-line-height--wide: $font-line-height-32;
$font-heading-l-size--narrow: $font-size-24;
$font-heading-l-line-height--narrow: $font-line-height-28;
$font-heading-l-family: $font-family-primary;
$font-heading-l-weight: $font-weight-black;
// Heading-xl font theme
$font-heading-xl-size--wide: $font-size-32;
$font-heading-xl-line-height--wide: $font-line-height-36;
$font-heading-xl-size--narrow: $font-size-28;
$font-heading-xl-line-height--narrow: $font-line-height-32;
$font-heading-xl-family: $font-family-primary;
$font-heading-xl-weight: $font-weight-extrablack;
// Heading-xxl font theme
$font-heading-xxl-size--wide: $font-size-48;
$font-heading-xxl-line-height--wide: $font-line-height-52;
$font-heading-xxl-size--narrow: $font-size-32;
$font-heading-xxl-line-height--narrow: $font-line-height-36;
$font-heading-xxl-family: $font-family-primary;
$font-heading-xxl-weight: $font-weight-extrablack;
// Heading-xs-italic font theme
$font-heading-xs-italic-size--wide: $font-size-16;
$font-heading-xs-italic-line-height--wide: $font-line-height-20;
$font-heading-xs-italic-size--narrow: $font-size-14;
$font-heading-xs-italic-line-height--narrow: $font-line-height-20;
$font-heading-xs-italic-family: $font-family-primary;
$font-heading-xs-italic-weight: $font-weight-black;
$font-heading-xs-italic-font-style: $font-style-italic;
// Heading-s-italic font theme
$font-heading-s-italic-size--wide: $font-size-20;
$font-heading-s-italic-line-height--wide: $font-line-height-24;
$font-heading-s-italic-size--narrow: $font-size-16;
$font-heading-s-italic-line-height--narrow: $font-line-height-20;
$font-heading-s-italic-family: $font-family-primary;
$font-heading-s-italic-weight: $font-weight-black;
