// Heading-m-italic font theme
$font-heading-m-italic-size--wide: $font-size-24;
$font-heading-m-italic-line-height--wide: $font-line-height-28;
$font-heading-m-italic-size--narrow: $font-size-20;
$font-heading-m-italic-line-height--narrow: $font-line-height-24;
$font-heading-m-italic-family: $font-family-primary;
$font-heading-m-italic-weight: $font-weight-black;
