{
  "$schema": "https://raw.githubusercontent.com/microsoft/vscode-html-languageservice/main/docs/customData.schema.json",
  "version": 1.1,
  "tags": [
    {
      "name": "pie-data-table",
      "description": "\n---\n\n\n### **Slots:**\n - **table-header** - Slot for custom table header content\n- _default_ - Default slot for when there is no data to display in the table",
      "attributes": [
        {
          "name": "columns",
          "description": "Array of column definitions",
          "values": [{ "name": "Column[]" }]
        },
        {
          "name": "data",
          "description": "Array of data objects to display",
          "values": [{ "name": "Record<string" }, { "name": "unknown>[]" }]
        },
        {
          "name": "additionalRows",
          "description": "Arbitrary additional rows to display at the bottom of the table",
          "values": [{ "name": "DataTableAdditionalRow[]" }]
        }
      ],
      "references": []
    },
    {
      "name": "pie-data-table-body",
      "description": "\n---\n\n\n### **Slots:**\n - _default_ - Default slot",
      "attributes": [],
      "references": []
