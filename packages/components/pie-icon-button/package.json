{
  "name": "@justeattakeaway/pie-icon-button",
  "version": "2.7.9",
  "description": "PIE Design System Icon Button built using Web Components",
  "repository": {
    "type": "git",
    "url": "https://github.com/justeattakeaway/pie",
    "directory": "packages/components/pie-icon-button"
  },
  "homepage": "https://webc.pie.design/?path=/docs/components-icon-button--overview",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "custom-elements.json",
    "src",
    "dist",
    "**/*.d.ts",
    "vscode.html-custom-data.json",
    "vscode.css-custom-data.json",
    "vue.d.ts"
  ],
  "pieMetadata": {
    "componentStatus": "stable",
    "replaces": {
      "snacks": [
        "IconButton"
      ]
    }
  },
  "scripts": {
    "build": "run -T vite build",
    "build:react-wrapper": "npx build-react-wrapper",
    "create:manifest": "run -T cem analyze --litelement",
    "lint:scripts": "run -T eslint .",
    "lint:scripts:fix": "run -T eslint . --fix",
    "lint:style": "run -T stylelint ./src/**/*.{css,scss}",
    "lint:style:fix": "yarn lint:style --fix",
    "watch": "run -T vite build --watch",
    "test:browsers": "npx playwright test -c ./playwright-lit.config.ts",
    "test:browsers:ci": "yarn test:browsers",
    "test:visual": "run -T cross-env-shell PERCY_TOKEN=${PERCY_TOKEN_PIE_ICON_BUTTON} percy exec --allowed-hostname cloudfront.net -- npx playwright test -c ./playwright-lit-visual.config.ts",
    "test:visual:ci": "yarn test:visual"
  },
  "author": "Just Eat Takeaway.com - Design System Team",
  "license": "Apache-2.0",
  "devDependencies": {
    "@justeattakeaway/pie-components-config": "0.21.0",
    "@justeattakeaway/pie-css": "1.1.1",
    "@justeattakeaway/pie-monorepo-utils": "0.9.0",
    "@justeattakeaway/pie-wrapper-react": "0.14.4"
  },
  "dependencies": {
    "@justeattakeaway/pie-icons-webc": "1.22.0",
    "@justeattakeaway/pie-spinner": "1.4.13",
    "@justeattakeaway/pie-webc-core": "14.0.1"
  },
  "volta": {
    "extends": "../../../package.json"
  },
  "customElements": "custom-elements.json",
  "sideEffects": [
    "dist/*.js"
  ]
}
