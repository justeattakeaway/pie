{
  "name": "@justeattakeaway/pie-lottie-player",
  "description": "PIE Design System Lottie Player built using Web Components",
  "version": "0.4.6",
  "repository": {
    "type": "git",
    "url": "https://github.com/justeattakeaway/pie",
    "directory": "packages/components/pie-lottie-player"
  },
  "homepage": "https://webc.pie.design/?path=/docs/components-lottie-player--overview",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "custom-elements.json",
    "src",
    "dist",
    "**/*.d.ts"
  ],
  "pieMetadata": {
    "componentStatus": "alpha",
    "replaces": {
      "snacks": []
    }
  },
  "scripts": {
    "build": "run -T vite build",
    "build:react-wrapper": "run -T build-react-wrapper",
    "create:manifest": "run -T cem analyze --litelement",
    "lint:scripts": "run -T eslint .",
    "lint:scripts:fix": "yarn lint:scripts --fix",
    "watch": "run -T vite build --watch",
    "test:browsers": "run -T playwright test -c ./playwright-lit.config.ts",
    "test:browsers:ci": "yarn test:browsers",
    "test:visual": "run -T cross-env-shell PERCY_TOKEN=${PERCY_TOKEN_PIE_LOTTIE_PLAYER} percy exec --allowed-hostname cloudfront.net -- run -T playwright test -c ./playwright-lit-visual.config.ts",
    "test:visual:ci": "yarn test:visual"
  },
  "author": "Just Eat Takeaway.com - Design System Team",
  "license": "Apache-2.0",
  "devDependencies": {
    "@justeattakeaway/pie-components-config": "0.21.3",
    "@justeattakeaway/pie-css": "1.2.0",
    "@justeattakeaway/pie-monorepo-utils": "0.9.6"
  },
  "dependencies": {
    "@justeattakeaway/pie-webc-core": "15.0.1",
    "lottie-web": "5.13.0"
  },
  "customElements": "custom-elements.json",
  "sideEffects": [
    "dist/*.js"
  ]
}
