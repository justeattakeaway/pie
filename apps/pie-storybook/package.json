{
  "name": "@justeattakeaway/pie-storybook",
  "version": "1.85.1",
  "private": true,
  "description": "Storybook for PIE Design System components",
  "scripts": {
    "dev": "storybook dev -p 6006",
    "dev:testing": "BROWSER_TESTING=true storybook dev -p 6007",
    "build": "storybook build --output-dir dist && cp -R ./static ./dist",
    "build:testing": "BROWSER_TESTING=true storybook build --output-dir dist && cp -R ./static ./dist",
    "lint:scripts": "run -T eslint .",
    "lint:scripts:fix": "run -T eslint . --fix",
    "test": "run -T vitest run test",
    "test:ci": "yarn test"
  },
  "author": "Just Eat Takeaway.com - Design System Team",
  "license": "Apache-2.0",
  "dependencies": {
    "@justeat/pie-design-tokens": "7.14.1",
    "@justeattakeaway/pie-css": "1.3.0",
    "@justeattakeaway/pie-icons-webc": "1.26.0",
    "@justeattakeaway/pie-webc": "0.10.31",
    "dompurify": "3.4.8"
  },
  "devDependencies": {
    "@justeattakeaway/pie-icons-configs": "5.21.0",
    "@justeattakeaway/pie-monorepo-utils": "0.9.6",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-designs": "11.1.3",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-links": "10.4.6",
    "@storybook/html": "10.4.6",
    "@storybook/web-components": "10.4.6",
    "@storybook/web-components-vite": "10.4.6",
    "@types/dompurify": "3.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-syntax-highlighter": "16.1.1",
    "remark-gfm": "4.0.1",
    "storybook": "10.4.6",
    "storybook-dark-mode": "5.0.0"
  },
  "installConfig": {
    "hoistingLimits": "workspaces"
  }
}
