{
  "name": "@justeattakeaway/pie-storybook",
  "version": "1.75.1",
  "private": true,
  "description": "Storybook for PIE Design System components",
  "scripts": {
    "dev": "storybook dev -p 6006",
    "dev:testing": "BROWSER_TESTING=true storybook dev -p 6007",
    "build": "storybook build --output-dir dist && cp -R ./static ./dist",
    "build:testing": "BROWSER_TESTING=true storybook build --output-dir dist && cp -R ./static ./dist",
    "build:chromatic": "BROWSER_TESTING=true storybook build",
    "lint:scripts": "run -T eslint .",
    "lint:scripts:fix": "run -T eslint . --fix",
    "test": "run -T vitest run test",
    "test:ci": "yarn test"
  },
  "author": "Just Eat Takeaway.com - Design System Team",
  "license": "Apache-2.0",
  "dependencies": {
    "@justeat/pie-design-tokens": "7.11.1",
    "@justeattakeaway/pie-css": "1.1.0",
    "@justeattakeaway/pie-icons-webc": "1.21.5",
    "@justeattakeaway/pie-webc": "0.10.2",
    "dompurify": "3.3.3"
  },
  "devDependencies": {
    "@justeattakeaway/pie-icons-configs": "5.21.0",
    "@justeattakeaway/pie-monorepo-utils": "0.9.0",
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/addon-designs": "11.1.3",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-links": "10.3.5",
    "@storybook/html": "10.3.5",
    "@storybook/web-components": "10.3.5",
    "@storybook/web-components-vite": "10.3.5",
    "@types/dompurify": "3.0.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-syntax-highlighter": "15.6.6",
    "remark-gfm": "4.0.1",
    "serve": "14.2.6",
    "storybook": "10.3.5",
    "storybook-dark-mode": "5.0.0"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "installConfig": {
    "hoistingLimits": "workspaces"
  }
}
