{
  "name": "@justeattakeaway/pie-storybook",
  "version": "1.70.1",
  "private": true,
  "description": "Storybook for PIE Design System components",
  "scripts": {
    "generate:typography-docs": "node scripts/generate-typography-docs.js",
    "dev": "storybook dev -p 6006",
    "dev:testing": "BROWSER_TESTING=true storybook dev -p 6007",
    "build": "storybook build --output-dir dist && cp -R ./static ./dist",
    "build:testing": "BROWSER_TESTING=true storybook build --output-dir dist && cp -R ./static ./dist",
    "build:chromatic": "BROWSER_TESTING=true storybook build",
    "lint:scripts": "run -T eslint .",
    "lint:scripts:fix": "run -T eslint . --fix",
    "test": "run -T vitest run test",
    "test:ci": "yarn test"
  },
  "author": "Just Eat Takeaway.com - Design System Team",
  "license": "Apache-2.0",
  "dependencies": {
    "@justeat/pie-design-tokens": "7.11.1",
    "@justeattakeaway/pie-css": "0.28.1",
    "@justeattakeaway/pie-icons-webc": "1.20.4",
    "@justeattakeaway/pie-webc": "0.8.6",
    "dompurify": "3.1.3"
  },
  "devDependencies": {
    "@justeattakeaway/pie-icons-configs": "5.21.0",
    "@justeattakeaway/pie-monorepo-utils": "0.7.0",
    "@storybook/addon-a11y": "8.4.5",
    "@storybook/addon-designs": "8.0.4",
    "@storybook/addon-essentials": "8.4.5",
    "@storybook/addon-links": "8.4.5",
    "@storybook/blocks": "8.4.5",
    "@storybook/components": "8.4.5",
    "@storybook/manager-api": "8.4.5",
    "@storybook/preview-api": "8.4.5",
    "@storybook/theming": "8.4.5",
    "@storybook/types": "8.4.5",
    "@storybook/web-components": "8.4.5",
    "@storybook/web-components-vite": "8.4.5",
    "@types/dompurify": "3.0.5",
    "@types/react-syntax-highlighter": "15.5.13",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-syntax-highlighter": "15.6.1",
    "remark-gfm": "4.0.1",
    "serve": "14.2.0",
    "storybook": "8.4.5",
    "storybook-dark-mode": "4.0.2"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "installConfig": {
    "hoistingLimits": "workspaces"
  }
}
