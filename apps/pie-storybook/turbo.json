{
  "$schema": "https://turborepo.org/schema.json",
  "extends": [
    "//"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "dependsOn": [
        "^build",
        "^generate:component-statuses",
        "^generate:typography-docs"
      ]
    },
    "dev:testing": {
      "cache": false,
      "dependsOn": [
        "^build",
        "^generate:component-statuses"
      ]
    },
    "build": {
      "cache": true,
      "dependsOn": [
        "^build",
        "^generate:component-statuses",
        "^generate:typography-docs"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "build:testing": {
      "cache": true,
      "dependsOn": [
        "^build",
        "^generate:component-statuses"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "test": {
      "cache": true,
      "dependsOn": []
    }
  }
}
