{
  "name": "pie-monorepo",
  "description": "The home of Just Eat Takeaway.com's PIE Design System",
  "version": "2.104.0",
  "repository": "justeattakeaway/pie",
  "homepage": "https://pie.design/",
  "keywords": [],
  "author": "Just Eat Takeaway.com - Design System Team",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": "^22 || ^24"
  },
  "packageManager": "yarn@3.8.1",
  "workspaces": {
    "packages": [
      "apps/**/*",
      "configs/**/*",
      "packages/**/*"
    ]
  },
  "scripts": {
    "analyse-component-bundles": "bundlewatch --config bundlewatch.config.json",
    "watch": "turbo run watch",
    "build": "cross-env-shell turbo run build --token=${TURBO_TOKEN}",
    "build:testing": "cross-env-shell turbo run build:testing --token=${TURBO_TOKEN}",
    "build:chromatic": "cross-env-shell turbo run build:chromatic --token=${TURBO_TOKEN} -- --output-dir dist",
    "build:dev": "cross-env-shell turbo run build:dev --token=${TURBO_TOKEN}",
    "build:react-wrapper": "cross-env-shell turbo run build:react-wrapper --token=${TURBO_TOKEN}",
    "create:manifest": "cross-env-shell turbo run create:manifest --token=${TURBO_TOKEN}",
    "changeset": "changeset && npx detect-webc-major-version",
    "changeset:publish": "changeset publish",
    "changeset:snapshot": "changeset version --snapshot snapshot-release",
    "changeset:version": "./packages/tools/pie-monorepo-utils/preserve-peer-dep-ranges/changeset-version.sh",
    "chromatic": "chromatic --exit-zero-on-changes",
    "clean": "turbo run clean",
    "cz": "./packages/tools/pie-monorepo-utils/git-hooks/check-branch-name.js $(git symbolic-ref --short HEAD) && ./node_modules/cz-customizable/standalone.js",
    "dev": "turbo run dev",
    "dev:testing": "turbo run dev:testing",
    "generate:component-statuses": "turbo run generate:component-statuses",
    "lint:config:fix": "eslint --fix turbo.json (packages|apps)/**/turbo.json",
    "lint:scripts": "cross-env-shell turbo run lint:scripts --token=${TURBO_TOKEN}",
    "lint:scripts:fix": "turbo run lint:scripts:fix",
    "lint:style": "cross-env-shell turbo run lint:style --continue --token=${TURBO_TOKEN}",
    "lint:style:fix": "turbo run lint:style:fix",
    "postinstall": "husky install",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable",
    "test": "cross-env-shell turbo run test --token=${TURBO_TOKEN}",
    "test:watch": "cross-env-shell turbo run test:watch",
    "test:ci": "cross-env-shell turbo run test:ci --token=${TURBO_TOKEN}",
    "test:coverage": "turbo run test:coverage",
    "test:generate-routes": "turbo run test:generate-routes --token=${TURBO_TOKEN}",
    "test:browsers-setup": "turbo run test:browsers-setup --token=${TURBO_TOKEN}",
    "test:browsers": "cross-env-shell turbo run test:browsers --token=${TURBO_TOKEN}",
    "test:browsers:react": "cross-env-shell turbo run test:browsers:react --token=${TURBO_TOKEN}",
    "test:browsers:webc": "cross-env-shell turbo run test:browsers:webc --token=${TURBO_TOKEN}",
    "test:browsers:ci": "cross-env-shell turbo run test:browsers:ci --token=${TURBO_TOKEN}",
    "test:visual": "turbo run test:visual",
    "test:visual:ci": "turbo run test:visual:ci"
  },
  "stylelint": {
    "extends": "@justeattakeaway/stylelint-config-pie/base",
    "rules": {
      "@justeattakeaway/pie-design-tokens": true
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@babel/preset-env": "7.29.2",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@justeat/pie-design-tokens": "7.11.1",
    "@justeattakeaway/browserslist-config-pie": "0.2.1",
    "@justeattakeaway/generator-pie-component": "0.33.0",
    "@justeattakeaway/pie-icons": "5.24.1",
    "@justeattakeaway/pie-webc-testing": "0.13.5",
    "@justeattakeaway/pie-wrapper-react": "0.14.4",
    "@justeattakeaway/stylelint-config-pie": "3.0.1",
    "@percy/cli": "1.31.1",
    "@percy/playwright": "1.0.9",
    "@playwright/experimental-ct-react": "1.57.0",
    "@playwright/test": "1.57.0",
    "@stylistic/stylelint-plugin": "4.0.0",
    "@types/node": "24.10.1",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "@vitest/coverage-v8": "4.0.17",
    "bundlewatch": "0.4.1",
    "chromatic": "13.3.5",
    "commitizen": "4.3.1",
    "cross-env": "7.0.3",
    "cz-customizable": "7.5.4",
    "danger": "13.0.7",
    "eslint": "8.57.0",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-json-format": "2.0.1",
    "eslint-plugin-vitest": "0.5.4",
    "glob": "10.5.0",
    "husky": "8.0.3",
    "jsdom": "24.1.3",
    "pinst": "3.0.0",
    "rimraf": "5.0.10",
    "rollup-plugin-visualizer": "5.12.0",
    "sass": "1.60.0",
    "stylelint": "16.2.1",
    "stylelint-config-standard-scss": "13.0.0",
    "stylelint-order": "6.0.4",
    "ts-node": "10.9.2",
    "tsx": "4.19.4",
    "turbo": "2.9.6",
    "typescript": "5.9.3",
    "vite": "6.4.2",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.0.17"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": ".cz-config.js"
    }
  },
  "volta": {
    "node": "24.11.1",
    "yarn": "3.8.1"
  },
  "resolutions": {
    "lit": "3.2.0",
    "tar": "6.2.1",
    "typescript": "5.8.3"
  }
}
