{
  "$schema": "https://turborepo.org/schema.json",
  "envMode": "loose",
  "tasks": {
    "build": {
      "cache": true,
      "dependsOn": [
        "^build",
        "build:react-wrapper"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "build:react-wrapper": {
      "cache": true,
      "dependsOn": [
        "create:manifest"
      ],
      "inputs": [
        "src/**",
        "custom-elements.json"
      ],
      "outputs": [
        "src/**/react.ts"
      ]
    },
    "create:manifest": {
      "cache": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/configs/pie-components-config/custom-elements-manifest.config.js"
      ],
      "outputs": [
        "custom-elements.json",
        "vscode.html-custom-data.json",
        "vscode.css-custom-data.json",
        "vue.d.ts"
      ]
    },
    "generate:component-statuses": {},
    "generate:typography-docs": {},
    "watch": {
      "cache": false,
      "dependsOn": []
    },
    "clean": {
      "cache": false,
      "dependsOn": []
    },
    "test": {
      "cache": true,
      "dependsOn": [
        "build",
        "^test"
      ],
      "outputs": [
        "**/__snapshots__/**",
        "**/snapshots/**"
      ]
    },
    "test:watch": {
      "cache": false,
      "dependsOn": [
        "build",
        "^test"
      ]
    },
    "test:ci": {
      "cache": true,
      "dependsOn": [
        "build",
        "^test:ci"
      ],
      "outputs": [
        "**/__snapshots__/**",
        "**/snapshots/**"
      ]
    },
    "test:coverage": {
      "cache": false
    },
    "test:browsers-setup": {
      "cache": true,
      "inputs": [
        "./configs/pie-components-config/playwright/index.html",
        "./configs/pie-components-config/playwright/index.ts"
      ],
      "outputs": [
        "**/playwright/index.html",
        "**/playwright/index.ts"
      ]
    },
    "test:browsers": {
      "cache": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        "!README.md",
        "!CHANGELOG.md",
        "!docs/**",
        "$TURBO_ROOT$/configs/pie-components-config/playwright-native-config.ts",
        "$TURBO_ROOT$/configs/pie-components-config/playwright/index.html",
        "$TURBO_ROOT$/configs/pie-components-config/playwright/index.ts"
      ],
      "outputs": []
    },
    "test:browsers:ci": {
      "cache": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        "!README.md",
        "!CHANGELOG.md",
        "!docs/**",
        "$TURBO_ROOT$/configs/pie-components-config/playwright-native-config.ts",
        "$TURBO_ROOT$/configs/pie-components-config/playwright/index.html",
        "$TURBO_ROOT$/configs/pie-components-config/playwright/index.ts"
      ]
    },
    "test:visual": {
      "cache": false,
      "inputs": [
        "$TURBO_DEFAULT$",
        "!README.md",
        "!CHANGELOG.md",
        "!docs/**",
        "$TURBO_ROOT$/configs/pie-components-config/playwright-native-visual-config.ts",
        "$TURBO_ROOT$/configs/pie-components-config/playwright/index.html",
        "$TURBO_ROOT$/configs/pie-components-config/playwright/index.ts"
      ]
    },
    "test:visual:ci": {
      "cache": false,
      "inputs": [
        "$TURBO_DEFAULT$",
        "!README.md",
        "!CHANGELOG.md",
        "!docs/**",
        "$TURBO_ROOT$/configs/pie-components-config/playwright-native-visual-config.ts",
        "$TURBO_ROOT$/configs/pie-components-config/playwright/index.html",
        "$TURBO_ROOT$/configs/pie-components-config/playwright/index.ts"
      ]
    },
    "lint:scripts": {
      "cache": true,
      "outputs": []
    },
    "lint:scripts:fix": {
      "cache": false
    },
    "lint:style": {
      "cache": true,
      "dependsOn": ["@justeattakeaway/pie-css#build"],
      "outputs": []
    },
    "lint:style:fix": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "dependsOn": [
        "^build"
      ]
    }
  }
}
